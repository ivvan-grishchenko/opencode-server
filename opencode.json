{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {
      "options": {
        "apiKey": "{env:OPENCODE_GO_API_KEY}"
      }
    }
  },
  "model": "opencode-go/kimi-k2.7-code",
  "small_model": "opencode-go/deepseek-v4-flash",
  "server": {
    "hostname": "127.0.0.1",
    "port": 4096
  },
  "share": "disabled",
  "autoupdate": false,
  "snapshot": true,
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "write": "ask"
  }
}
