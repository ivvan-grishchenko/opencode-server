# Copy this file to .env for local testing only.
# On Railway, set these variables in the service dashboard (encrypted).

# Required: GitHub personal access token with `repo` scope.
# Used by the GitHub CLI to clone and update private/public repos.
GITHUB_TOKEN=ghp_your_github_token_here

# Required: OpenCode Go provider API key.
# Get it from https://opencode.ai/auth after subscribing to OpenCode Go.
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here

# Required: password for HTTP Basic Auth on the public proxy.
OPENCODE_SERVER_PASSWORD=your_strong_password_here

# Optional: username for HTTP Basic Auth (default: opencode).
OPENCODE_SERVER_USERNAME=opencode

# Required: JSON array of repos to clone.
# Each repo gets its own OpenCode backend and is reachable at /<name>/.
REPOS_JSON=[{"name":"repo-a","owner":"myorg","repo":"repo-a","branch":"main"},{"name":"repo-b","owner":"myorg","repo":"repo-b","branch":"main"}]

# Optional: local test port. Railway injects PORT automatically.
PORT=3000

# Internal paths. Keep these values for Railway volume persistence.
XDG_CONFIG_HOME=/data/config
XDG_DATA_HOME=/data/local
XDG_CACHE_HOME=/data/cache
REPOS_DIR=/data/repos
